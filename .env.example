GOOGLE_API_KEY=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GROQ_API_KEY=
APIFY_TOKEN=
YOUTUBE_API_KEY=

LLM_MODEL=gemini-2.5-flash-lite
EMBED_MODEL=models/gemini-embedding-001
EMBED_DIM=768
WHISPER_MODEL=whisper-large-v3-turbo

USE_FIXTURES=false
YOUTUBE_USE_APIFY=false

# Hosts below use localhost for local dev. On the droplet (docker-compose.prod.yml)
# swap them to the docker SERVICE NAMES: postgres / redis / qdrant.
DATABASE_URL=postgresql://creatorrag:creatorrag@localhost:5432/creatorrag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=video_chunks

# Comma-separated allowed origins for the browser. In prod set this to your
# Vercel URL, e.g. https://creatorrag.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:3000

# Production only (used by Caddy in docker-compose.prod.yml): the public
# hostname Caddy gets an HTTPS cert for. Leave blank for local dev.
SITE_ADDRESS=
# Production only: set a strong Postgres password on the droplet.
POSTGRES_PASSWORD=
