# ── CreatorRAG environment ────────────────────────────────────────────────
# Copy to `.env` (repo root) and fill in. Backend reads this file directly.
# Frontend reads NEXT_PUBLIC_* vars (see frontend/.env.local.example).

# ── LLM + embeddings (REQUIRED) ───────────────────────────────────────────
# Google AI Studio key — free tier is plenty for this assignment.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Models. gemini-embedding-001 because text-embedding-004 was deprecated Jan 2026.
LLM_MODEL=gemini-2.5-flash
EMBED_MODEL=models/gemini-embedding-001
EMBED_DIM=768

# ── Transcription (REQUIRED for real videos) ──────────────────────────────
# Groq Whisper. Free tier ~2000 req/day. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
WHISPER_MODEL=whisper-large-v3-turbo

# ── Instagram scraping (REQUIRED for live IG; optional in fixture mode) ────
# Apify free account gives $5 credits/month, no card.
# Get a token at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Demo kill-switch: when true, Instagram URLs are served from local fixtures
# (backend/fixtures/*.json + audio) so the demo never depends on live IG.
# Also auto-engaged if Apify fails and a matching fixture exists.
USE_FIXTURES=true

# ── Infrastructure ────────────────────────────────────────────────────────
# Local dev (docker compose). For Supabase, paste the connection string
# (Project Settings → Database → Connection string → URI, use the pooler).
DATABASE_URL=postgresql://creatorrag:creatorrag@localhost:5432/creatorrag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=video_chunks

# ── Chunking ──────────────────────────────────────────────────────────────
CHUNK_TOKENS=400
CHUNK_OVERLAP=60

# ── App ───────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000
